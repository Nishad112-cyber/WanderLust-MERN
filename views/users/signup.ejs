<% layout("/layouts/boilerplate") %>

<div class="row row"> 
    <h1 class="col-12 col-md-6 offset-md-3 text-center text-md-start">Signup for wanderlust</h1>
<div class="col-12 col-md-6 offset-md-3">
    <form action="/signup" method="POST" class="needs-validation" novalidate>
     <div class="mb-3 ">
            <label for="username" class="form-label">username</label>
            <input 
             name="username"
             id="username"
             type="text"
             class="form-control"
             required
           /> 
           <div class="valid-feedback">
           good fills.
         </div> 
        </div>
        <div class="mb-3 ">
            <label for="email" class="form-label">E-mail</label>
            <input 
             name="email"
             id="email"
             type="email"
             class="form-control"
             required
           /> 
        </div>
         <div class="mb-3 ">
            <label for="password" class="form-label">password</label>
            <input 
             name="password"
             id="password"
             type="password"
             class="form-control"
           /> 
        </div>
        <br>
         
           <div class="d-grid gap-2">
            <button class="btn btn-success">Sign Up</button>
         </div>

    </form>
    </div>
    </div>
